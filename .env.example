# Server
PORT=3456
HOST=0.0.0.0
NODE_ENV=development

# JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# GitHub OAuth
# Create an OAuth app: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
# Create credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Discord Bot (API key for bot to authenticate with this API)
DISCORD_BOT_API_KEY=change-me-bot-key

# Your deployed API URL (no trailing slash) — this is your Railway-generated URL
BASE_URL=https://CHANGE-ME-TO-YOUR-RAILWAY-URL.up.railway.app

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:1420,http://localhost:5173,tauri://localhost
